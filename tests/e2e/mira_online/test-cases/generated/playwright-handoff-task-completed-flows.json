[
  {
    "id": "TC-CDP-FLOWS-001",
    "storyId": "US-TASK-COMPLETED-CROSS",
    "title": "share 对话框 → 复制链接 → 关闭 → 点击 follow-up → log 新增 user-message",
    "priority": "P2",
    "tags": ["@P2", "@regression", "@full"],
    "preconditions": ["已登录 + fixture shareUrl"],
    "setup": [
      { "type": "fixture", "fixtureId": "share" }
    ],
    "uiElements": [
      { "role": "navigation", "name": "share task page", "action": "goto" },
      { "role": "button", "name": "share2 button", "action": "click" },
      { "role": "button", "name": "copy link", "action": "click", "i18nKey": "chatbot.copyLink" },
      { "role": "button", "name": "close dialog", "action": "click" },
      { "role": "button", "name": "first follow-up", "action": "click" }
    ],
    "assertions": [
      { "type": "clipboardMatches", "selector": "navigator.clipboard", "pattern": "/share/.+token=" },
      { "type": "hidden", "selector": "[role='dialog']" },
      { "type": "count", "selector": "[role='log'] .is-user", "expected": "N+1", "comparator": "delta" }
    ],
    "timeout": 360000
  },
