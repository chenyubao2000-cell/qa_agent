[
  {
    "id": "TC-CDP-CONV-001",
    "storyId": "US-CONV-FILEUPLOAD",
    "source": "cdp",
    "title": "附加支持格式文件后 Submit 按钮变为可点击",
    "priority": "P0",
    "scenarioType": "positive",
    "preconditions": ["已登录，位于 /task 空会话页面（S0）"],
    "setup": [
      { "type": "navigate", "action": "navigate", "pomMethod": "goto", "data": {} }
    ],
    "action": "通过隐藏文件 input 上传 sample.pdf",
    "expectedOutcome": "附件区显示文件名，Submit 按钮变为可点击状态",
    "uiElements": [
      {
        "role": "button",
        "name": "添加照片或文件",
        "i18nKey": "chatbot.addAttachments",
        "action": "trigger",
        "locatorHint": "button:has-text('添加照片或文件')"
      },
      {
        "role": "input",
        "tag": "input[type=file]",
        "action": "setInputFiles",
        "value": "tests/e2e/test-data/files/sample.pdf",
        "dataType": "file.document",
        "dataVariant": "pdf",
        "locatorHint": "input[type='file']"
      }
    ],
    "assertions": [
      {
        "type": "visible",
        "selector": "button:has-text('Remove attachment')",
        "description": "附件移除按钮可见"
      },
      {
        "type": "enabled",
        "selector": "button:has-text('Submit')",
        "description": "Submit 按钮变为可点击"
      }
    ],
    "teardown": [],
    "tags": ["cdp-inferred", "file-upload", "@P0", "@smoke", "@regression", "@full"],
    "timeout": 15000,
    "pageUrl": "https://www.mira.day/task",
    "fromState": "S0",
    "toState": "S1"
  },
