    "id": "TC-CDP-CONV-010",
    "storyId": "US-CONV-FILEUPLOAD",
    "source": "cdp",
    "title": "文件附加与移除的完整状态流转（S0→S1→S0）",
    "priority": "P0",
    "scenarioType": "positive",
    "preconditions": ["已登录，位于 /task 空会话页面（S0）"],
    "setup": [
      { "type": "navigate", "action": "navigate", "pomMethod": "goto", "data": {} }
    ],
    "action": "上传 sample.pdf → 确认 S1 → 点击 Remove attachment → 确认 S0",
    "expectedOutcome": "全程状态转换正确，Submit 按钮状态与附件状态联动",
    "uiElements": [
      {
        "role": "input",
        "tag": "input[type=file]",
        "action": "setInputFiles",
        "value": "tests/e2e/test-data/files/sample.pdf",
        "dataType": "file.document",
        "dataVariant": "pdf",
        "locatorHint": "input[type='file']"
      },
      {
        "role": "button",
        "name": "Remove attachment",
        "action": "click",
        "locatorHint": "button:has-text('Remove attachment')"
      }
    ],
    "assertions": [
      {
        "type": "enabled",
        "selector": "button:has-text('Submit')",
        "description": "文件附加后 Submit 启用（S1 验证点）"
      },
      {
        "type": "disabled",
        "selector": "button:has-text('Submit')",
        "description": "文件移除后 Submit 重新禁用（S0 验证点）"
      }
    ],
