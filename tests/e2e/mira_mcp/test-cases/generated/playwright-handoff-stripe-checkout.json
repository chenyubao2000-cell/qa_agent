  {
    "id": "TC-CSO-008",
    "storyId": "REQ-003",
    "title": "跳转超过 5 秒展示「点击此处手动跳转」链接",
    "priority": "P1",
    "source": "prd",
    "feature": "stripe-checkout",
    "preconditions": [
      "用户已登录",
      "用户无 active 订阅",
      "可注入网络延迟到 Checkout Session 创建请求（路由拦截 6 秒）"
    ],
    "setup": [
      { "type": "route-intercept", "action": "delay", "data": { "urlPattern": "**/checkout-session**", "delayMs": 6000 } },
      { "type": "navigate", "action": "navigate", "pomMethod": "pricingPage.goto", "data": {} }
    ],
    "uiElements": [
      { "name": "starterUpgradeButton", "role": "button", "textHint": "Upgrade", "context": "Starter card", "i18nKey": null },
      { "name": "manualRedirectLink", "role": "link", "textHint": "Click here to continue manually", "i18nKey": null }
    ],
    "steps": [
      "通过 route-intercept 注入 6s 延迟到创建 Session 的 endpoint",
      "进入定价页",
      "点击 Starter Upgrade",
      "等待 5+ 秒"
    ],
    "assertions": [
      { "type": "url-host", "expected": "<mira-base-host>", "note": "still on Mira after 5s" },
      { "type": "element-visible", "target": "manualRedirectLink", "expectedText": "Click here to continue manually", "timeoutMs": 8000 }
    ],
    "teardown": [
      { "type": "route-cleanup", "data": { "urlPattern": "**/checkout-session**" } }
    ],
    "outOfApp": [],
    "testData": { "networkDelayMs": 6000 }
  },
