  {
    "id": "TC-CSO-006",
    "storyId": "REQ-003",
    "title": "Stripe Test Mode 用 4242 测试卡完成支付，跳回 Mira 成功页",
    "priority": "P0",
    "source": "prd",
    "feature": "stripe-checkout",
    "preconditions": [
      "用户已登录",
      "用户无 active 订阅",
      "Stripe 沙箱启用",
      "测试卡 4242 4242 4242 4242 可用"
    ],
    "setup": [
      { "type": "navigate", "action": "navigate", "pomMethod": "pricingPage.goto", "data": {} }
    ],
    "uiElements": [
      { "name": "individualUpgradeButton", "role": "button", "textHint": "Upgrade", "context": "Individual card", "i18nKey": null }
    ],
    "steps": [
      "进入定价页",
      "点击 Individual Upgrade",
      "等待跳转到 checkout.stripe.com",
      "[out-of-app] 在 Stripe 托管页输入 4242 4242 4242 4242 / 任意未来过期日 / 任意 CVC / 任意邮编",
      "[out-of-app] 提交支付",
      "等待跳回 Mira"
    ],
    "assertions": [
      { "type": "url-host", "expected": "checkout.stripe.com", "timeoutMs": 10000, "note": "intermediate state" },
      { "type": "url-host-back", "expected": "<mira-base-host>", "timeoutMs": 60000, "note": "final return to Mira" },
      { "type": "url-path-contains", "expected": "success", "note": "success page path" },
      { "type": "url-query-has", "expected": "session_id", "valueRegex": "^cs_test_[A-Za-z0-9]+$" }
    ],
    "teardown": [
      { "type": "fixture-cleanup", "note": "支付成功会创建真实订阅记录，需要在沙箱环境中通过后端 API 或 Stripe Dashboard 清理（超出 e2e 直接控制范围，由运维流程兜底）" }
    ],
    "outOfApp": [
      "Stripe hosted page card input",
      "Stripe hosted page submit",
      "SCA / 3DS challenge if any"
    ],
    "testData": { "card": "4242424242424242", "expiry": "any-future", "cvc": "any", "zip": "any", "plan": "Individual" }
  },
