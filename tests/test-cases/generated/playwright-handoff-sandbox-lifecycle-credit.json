[
  {
    "id": "TC-PRD-SLC-001",
    "storyId": "US-SLC-REQ001",
    "criterionId": "AC-REQ001-01,AC-REQ001-04,AC-REQ002-01,AC-REQ002-02,AC-REQ003-01",
    "source": "prd",
    "title": "完整正向生命周期：创建→连续工具执行→COMPLETED→pause + 全链计费验证",
    "priority": "P0",
    "scenarioType": "positive",
    "mergedFrom": ["TC-001", "TC-004", "TC-005", "TC-009", "TC-016", "TC-019", "TC-024", "TC-027", "TC-029"],
    "preconditions": ["用户已登录", "session 中无历史沙箱记录", "沙箱不存在（null）"],
    "setup": [
      { "type": "mcp", "action": "navigate", "tool": "mcp__chrome-devtools__navigate_page", "params": { "url": "{PREVIEW_URL}/task" } },
      { "type": "mcp", "action": "click", "tool": "mcp__chrome-devtools__click", "params": { "selector": "[data-testid='new-task-button']" }, "description": "点击新建任务" },
      { "type": "mcp", "action": "wait", "tool": "mcp__chrome-devtools__wait_for", "params": { "selector": "[data-testid='task-prompt']" }, "description": "等待我能为你做什么" },
      { "type": "mcp", "action": "snapshot", "tool": "mcp__chrome-devtools__take_snapshot", "description": "获取页面快照" },
      { "type": "mcp", "action": "click", "tool": "mcp__chrome-devtools__click", "params": { "selector": "[data-testid='message-input']" } },
      { "type": "mcp", "action": "type", "tool": "mcp__chrome-devtools__type_text", "params": { "text": "寻访互联网行业 10 年经验技术负责人，创建候选人档案并执行初步匹配" } },
      { "type": "mcp", "action": "snapshot", "tool": "mcp__chrome-devtools__take_snapshot", "description": "获取新 uid" },
      { "type": "mcp", "action": "click", "tool": "mcp__chrome-devtools__click", "params": { "selector": "[data-testid='send-button']" } },
      { "type": "mcp", "action": "wait", "tool": "mcp__chrome-devtools__wait_for", "params": { "selector": "[data-testid='tool-execution-bubble']" }, "description": "等待工具调用气泡出现 S0→S1" },
      { "type": "mcp", "action": "extract", "tool": "mcp__chrome-devtools__evaluate_script", "params": { "expression": "window.location.pathname.split('/').pop()" }, "output": "taskId" }
    ],
    "teardown": [],
    "uiElements": [
      { "role": "button", "name": "新建任务", "action": "click", "locatorHint": "[data-testid='new-task-button']" },
      { "role": "textbox", "name": "消息输入框", "action": "type", "value": "寻访互联网行业 10 年经验技术负责人，创建候选人档案并执行初步匹配", "locatorHint": "[data-testid='message-input']" },
      { "role": "button", "name": "Submit", "action": "click", "locatorHint": "[data-testid='send-button']" }
    ],
    "assertions": [
      { "type": "db_query", "query": "SELECT \"sandboxId\" FROM chats WHERE id = '{taskId}'", "field": "sandboxId", "expected": "NOT NULL", "description": "chats.sandboxId 非空（沙箱已创建）" },
      { "type": "e2b_api", "endpoint": "https://api.e2b.dev/sandboxes/{sandboxId}", "expected_status": "running", "description": "E2B API 确认沙箱 running（S1）" },
      { "type": "mcp_wait", "tool": "mcp__chrome-devtools__wait_for", "params": { "selector": "[data-testid='task-status-completed']" }, "description": "等待 COMPLETED S1→S2" },
      { "type": "e2b_api", "endpoint": "https://api.e2b.dev/sandboxes/{sandboxId}", "expected_status": "paused", "description": "E2B API 确认沙箱 paused（S2）" },
      { "type": "db_query", "query": "SELECT id, \"resumeAt\", \"pauseAt\", \"runningSeconds\", \"costUsd\", \"usageId\" FROM sandbox_run WHERE \"taskId\" = '{taskId}' ORDER BY \"resumeAt\" ASC", "field": "count", "expected": 1, "description": "仅 1 条 sandbox_run（连续工具调用不中断）" },
      { "type": "db_formula", "formula": "runningSeconds = CEIL((pauseAt - resumeAt) / 1000)", "description": "runningSeconds = ceil((pauseAt - resumeAt)/1000)" },
      { "type": "db_formula", "formula": "costUsd = runningSeconds * 0.000046", "description": "costUsd = runningSeconds × 0.000046" },
      { "type": "db_query", "query": "SELECT id, \"costSettled\", \"vendorRequestId\", status FROM mira_usage WHERE \"vendorRequestId\" = '{sandbox_run.id}' AND type = 'sandbox'", "field": "costSettled", "expected": "= sandbox_run.costUsd", "description": "mira_usage.costSettled = sandbox_run.costUsd" },
      { "type": "db_query", "query": "SELECT quantity, \"meterName\", cost FROM mira_usage_meter WHERE \"usageId\" = '{mira_usage.id}'", "field": "meterName", "expected": "sandbox_running_seconds", "description": "meterName = sandbox_running_seconds" },
      { "type": "db_query", "query": "SELECT \"rawCreditAmount\", \"creditsPerUnitSnapshot\" FROM mira_credit WHERE \"usageId\" = '{mira_usage.id}'", "field": "rawCreditAmount", "expected": "= costSettled * creditsPerUnitSnapshot", "description": "rawCreditAmount = costSettled × creditsPerUnitSnapshot" },
      { "type": "db_query", "query": "SELECT \"creditsPerUnit\" FROM credit_rate WHERE currency = 'USD' AND \"effectiveAt\" <= NOW() AND (\"expireAt\" IS NULL OR \"expireAt\" > NOW()) ORDER BY \"effectiveAt\" DESC LIMIT 1", "field": "creditsPerUnit", "expected": "NOT NULL", "description": "当前汇率存在" },
      { "type": "db_query", "query": "SELECT \"sumRaw\", \"carryBefore\", \"carryAfter\", amount, \"balanceAfter\" FROM mira_credit_ledger WHERE \"taskId\" = '{taskId}' ORDER BY \"createdAt\" DESC LIMIT 1", "field": "amount", "expected": "= -floor(sumRaw + carryBefore)", "description": "amount = -floor(sumRaw + carryBefore)" }
    ],
    "tags": ["@P0", "@smoke", "@regression", "@full", "@sandbox-lifecycle", "@billing-chain"],
    "timeout": 600000
  },
  {
    "id": "TC-PRD-SLC-002",
    "storyId": "US-SLC-REQ001",
    "criterionId": "AC-REQ001-02,AC-REQ001-06,AC-REQ002-03",
    "source": "prd",
    "title": "多轮 HITL 对话：WAITING→pause→resume→再次执行→COMPLETED（含多段计时累加）",
    "priority": "P0",
    "scenarioType": "positive",
    "mergedFrom": ["TC-002", "TC-015", "TC-017", "TC-020", "TC-025", "TC-026", "TC-031"],
    "preconditions": ["用户已登录", "任务需要人工确认（HITL 场景）"],
    "setup": [
      { "type": "mcp", "action": "navigate", "tool": "mcp__chrome-devtools__navigate_page", "params": { "url": "{PREVIEW_URL}/task" } },
      { "type": "mcp", "action": "click", "tool": "mcp__chrome-devtools__click", "params": { "selector": "[data-testid='new-task-button']" } },
      { "type": "mcp", "action": "wait", "tool": "mcp__chrome-devtools__wait_for", "params": { "selector": "[data-testid='task-prompt']" } },
      { "type": "mcp", "action": "snapshot", "tool": "mcp__chrome-devtools__take_snapshot" },
      { "type": "mcp", "action": "click", "tool": "mcp__chrome-devtools__click", "params": { "selector": "[data-testid='message-input']" } },
      { "type": "mcp", "action": "type", "tool": "mcp__chrome-devtools__type_text", "params": { "text": "创建候选人档案，完成后请先确认再执行匹配脚本" } },
      { "type": "mcp", "action": "snapshot", "tool": "mcp__chrome-devtools__take_snapshot" },
      { "type": "mcp", "action": "click", "tool": "mcp__chrome-devtools__click", "params": { "selector": "[data-testid='send-button']" } },
      { "type": "mcp", "action": "wait", "tool": "mcp__chrome-devtools__wait_for", "params": { "selector": "[data-testid='task-status-waiting']" }, "description": "等待 WAITING_FOR_USER" },
      { "type": "mcp", "action": "extract", "tool": "mcp__chrome-devtools__evaluate_script", "params": { "expression": "window.location.pathname.split('/').pop()" }, "output": "taskId" }
    ],
    "teardown": [],
    "uiElements": [
      { "role": "button", "name": "新建任务", "action": "click", "locatorHint": "[data-testid='new-task-button']" },
      { "role": "textbox", "name": "消息输入框", "action": "type", "value": "创建候选人档案，完成后请先确认再执行匹配脚本", "locatorHint": "[data-testid='message-input']" },
      { "role": "button", "name": "Submit", "action": "click", "locatorHint": "[data-testid='send-button']" }
    ],
    "assertions": [
      { "type": "db_query", "query": "SELECT \"sandboxId\" FROM chats WHERE id = '{taskId}'", "field": "sandboxId", "expected": "NOT NULL", "description": "sandboxId 非空" },
      { "type": "e2b_api", "endpoint": "https://api.e2b.dev/sandboxes/{sandboxId}", "expected_status": "paused", "description": "WAITING_FOR_USER 后 E2B 确认 paused" },
      { "type": "db_query", "query": "SELECT id, \"resumeAt\", \"pauseAt\", \"runningSeconds\", \"costUsd\", \"usageId\" FROM sandbox_run WHERE \"taskId\" = '{taskId}' ORDER BY \"resumeAt\" ASC", "description": "第 1 段 sandbox_run：pauseAt 非空" },
      { "type": "db_query", "query": "SELECT id, \"costSettled\", \"vendorRequestId\", status FROM mira_usage WHERE \"vendorRequestId\" = '{sandbox_run_1.id}' AND type = 'sandbox'", "field": "costSettled", "expected": "= sandbox_run_1.costUsd", "description": "第 1 段 mira_usage 增量写入" },
      { "type": "mcp_action", "tool": "mcp__chrome-devtools__type_text", "params": { "text": "确认，请继续执行后续匹配步骤" }, "description": "用户确认继续" },
      { "type": "e2b_api", "endpoint": "https://api.e2b.dev/sandboxes/{sandboxId}", "expected_status": "running", "description": "resume 后 E2B 确认 running" },
      { "type": "mcp_wait", "tool": "mcp__chrome-devtools__wait_for", "params": { "selector": "[data-testid='task-status-completed']" }, "description": "等待第 2 轮 COMPLETED" },
      { "type": "e2b_api", "endpoint": "https://api.e2b.dev/sandboxes/{sandboxId}", "expected_status": "paused", "description": "COMPLETED 后 E2B 确认 paused" },
      { "type": "db_query", "query": "SELECT id, \"resumeAt\", \"pauseAt\", \"runningSeconds\", \"costUsd\", \"usageId\" FROM sandbox_run WHERE \"taskId\" = '{taskId}' ORDER BY \"resumeAt\" ASC", "field": "count", "expected": 2, "description": "2 条 sandbox_run 记录" },
      { "type": "db_compare", "query": "SELECT * FROM sandbox_run WHERE \"taskId\" = '{taskId}' ORDER BY \"resumeAt\" ASC", "assertion": "row[1].resumeAt > row[0].pauseAt", "description": "第 2 条 resumeAt > 第 1 条 pauseAt（跨轮间隙不计费）" },
      { "type": "db_compare", "query": "SELECT * FROM sandbox_run WHERE \"taskId\" = '{taskId}' ORDER BY \"resumeAt\" ASC", "assertion": "row[0].sandboxId === row[1].sandboxId", "description": "sandboxId 复用" },
      { "type": "db_query", "query": "SELECT SUM(\"runningSeconds\") as total, SUM(\"costUsd\") as \"totalCost\" FROM sandbox_run WHERE \"taskId\" = '{taskId}'", "description": "各段 runningSeconds 之和 = 总运行时长" },
      { "type": "db_query", "query": "SELECT \"sumRaw\", \"carryBefore\", \"carryAfter\", amount, \"balanceAfter\" FROM mira_credit_ledger WHERE \"taskId\" = '{taskId}' ORDER BY \"createdAt\" DESC LIMIT 1", "field": "amount", "expected": "= -floor(sumRaw + carryBefore)", "description": "ledger amount 正确" }
    ],
    "tags": ["@P0", "@smoke", "@regression", "@full", "@sandbox-lifecycle", "@hitl", "@billing-chain"],
    "timeout": 900000
  },
