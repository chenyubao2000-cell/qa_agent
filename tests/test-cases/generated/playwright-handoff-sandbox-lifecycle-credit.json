      { "type": "db_query", "query": "SELECT \"sumRaw\", \"carryBefore\", \"carryAfter\", amount, \"balanceAfter\" FROM mira_credit_ledger WHERE \"taskId\" = '{taskId_2}' ORDER BY \"createdAt\" DESC LIMIT 1", "description": "任务 2：carryBefore = 任务 1 carryAfter（carry 链传递）" },
      { "type": "db_compare", "assertion": "taskId_2.carryBefore === taskId_1.carryAfter", "description": "carry 链连续性" },
      { "type": "db_query", "query": "SELECT \"sumRaw\", \"carryBefore\", \"carryAfter\", amount, \"balanceAfter\" FROM mira_credit_ledger WHERE \"taskId\" = '{taskId_3}' ORDER BY \"createdAt\" DESC LIMIT 1", "description": "任务 3：跨整数进位 |amount| >= 1" },
      { "type": "db_formula", "formula": "amount = -floor(sumRaw + carryBefore)", "description": "进位公式正确" },
      { "type": "db_formula", "formula": "carryAfter = (sumRaw + carryBefore) - floor(sumRaw + carryBefore)", "description": "carryAfter < 1.0" },
      { "type": "db_query", "query": "SELECT \"sumRaw\", \"carryBefore\", \"carryAfter\", amount FROM mira_credit_ledger WHERE \"userId\" = '{userId}' ORDER BY \"createdAt\" DESC LIMIT 1", "description": "Session 清算：carryAfter = 0" }
    ],
