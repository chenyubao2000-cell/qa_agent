# ── QA 工作空间，脚本生成和运行以及报告分析的根目录 ──────────────────────────────
QA_WORKSPACE_DIR=./tests/e2e/local
# QA_WORKSPACE_DIR="./cases"
# 源码目录（读源码用，默认同 QA_WORKSPACE_DIR）
SOURCE_PROJECT_DIR="D:\ling_work\code2026\mira"
# SOURCE_PROJECT_DIR=../preview/mira
TARGET_GITHUB_URL=https://github.com/MiraTeams/mira
TARGET_GITHUB_OWNER=MiraTeams
TARGET_GITHUB_REPO=mira
TARGET_BRANCH=preview_qa_automation

# ── 多语言测试（可选）──────────────────────────
# 逗号分隔的语言代码，设置后自动生成多 Playwright project（每语言一个）
# 不设置则单语言模式（默认 en-US）
APP_LANGUAGES=en
I18N_MESSAGES_DIR=./tests/e2e/mira_online/messages

# ── Preview 环境 ──────────────────────────────
PREVIEW_URL=https://mira-bff-preview.up.railway.app/
# PREVIEW_URL=https://mira-next-frontend-preview.up.railway.app/
# PREVIEW_URL=https://www.mira.day/
# PREVIEW_URL=https://localhost:3000/


