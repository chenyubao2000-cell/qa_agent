# ── Playwright ───────────────────────────────
# PLAYWRIGHT_BASE_URL 不再单独维护，统一从 PREVIEW_URL 读取
PLAYWRIGHT_HEADLESS=true

# ── 通知（可选）──────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# ── Tool Probe (/qa-tool-probe) ───────────────
# 跑 judge.ts 时使用，shell 出去调本地 claude -p CLI
JUDGE_LANG=zh                       # zh|en，judge 输出 reason 的语言
CLAUDE_JUDGE_CONCURRENCY=1          # 并发 claude -p 子进程数
CLAUDE_JUDGE_TIMEOUT=240            # 单次 judge 调用超时（秒）

 
