E2E_TEST_EMAIL=chenyubao2000@163.com
E2E_TEST_PASSWORD=11111
# E2E_TEST_PASSWORD=1111111111

# ── GitHub ───────────────────────────────────
GITHUB_TOKEN=xxx
GITHUB_OWNER=MiraTeams11
GITHUB_REPO=mira111

# ── Linear ───────────────────────────────────
LINEAR_API_KEY=111
LINEAR_PROJECT_ID=111
