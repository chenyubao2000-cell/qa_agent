{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "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",
        "HTTPS_PROXY": "http://127.0.0.1:7890",
        "HTTP_PROXY": "http://127.0.0.1:7890"
      }
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": ["--app", "desktop"],
      "env": {}
    },
    "linear": {
      "command": "node",
      "args": ["--import", "./scripts/proxy-bootstrap.mjs", "node_modules/@calltelemetry/linear-mcp/build/index.js"],
      "env": {
        "LINEAR_API_KEY": "lin_api_VCFHT6NCiBMoLma7CxfRCJMCl04RC6iWoxAnEIN4",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0",
        "GLOBAL_AGENT_HTTP_PROXY": "http://127.0.0.1:7890",
        "HTTPS_PROXY": "http://127.0.0.1:7890",
        "HTTP_PROXY": "http://127.0.0.1:7890"
      }
    }
  }
}
