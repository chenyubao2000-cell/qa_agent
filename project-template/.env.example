# ── 目标项目 ──────────────────────────────────
# 被测项目的本地路径（绝对路径），生成的 spec/POM/用例/报告写入此目录
QA_WORKSPACE_DIR=D:/code/your-project
# 源码目录（读源码用，默认同 QA_WORKSPACE_DIR。git-watcher 自动触发时会覆盖为 worktree 路径）
SOURCE_PROJECT_DIR=D:/code/your-project
# 目标项目的 GitHub 仓库信息（用于自动拉取代码和分析变更）
TARGET_GITHUB_URL=https://github.com/your-org/your-repo
TARGET_GITHUB_OWNER=your-org
TARGET_GITHUB_REPO=your-repo
TARGET_BRANCH=main

# ── Preview 环境 ──────────────────────────────
PREVIEW_URL=https://preview-xxxxx.your-domain.com

# ── GitHub ───────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# ── Linear ───────────────────────────────────
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx
LINEAR_PROJECT_ID=PROJECT_ID_THIS
LINEAR_TEAM_ID=TEAM_ID_HERE


# ── Webhook ─────────────────────────────────
WATCHER_INTERVAL=20

# ── Playwright ───────────────────────────────
PLAYWRIGHT_BASE_URL=${PREVIEW_URL}
PLAYWRIGHT_HEADLESS=true

# ── 测试账号（需要登录态的项目必填）────────────
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=your-test-password

# ── 通知（可选）──────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
